# 火山引擎 API 配置（LLM + Embedding）
VOLC_API_KEY=77194a73-ecb7-4371-bd76-cfe35a0c767b
VOLC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
VOLC_EMBEDDING_MODEL=doubao-embedding-vision
VOLC_LLM_MODEL=doubao-seed-2.0-pro

# ============================================================
# 腾讯云向量数据库配置（可选，仅 provider=tencent_cloud 时需要）
# 在 config.yaml 中设置 vector_store.provider = "tencent_cloud"
# ============================================================
TENCENT_VDB_HOST=http://10.0.X.X:80
TENCENT_VDB_KEY=your_api_key_here
TENCENT_VDB_USERNAME=root
TENCENT_VDB_DATABASE=insurance_db

# OpenAI 兼容配置（备选）
OPENAI_API_KEY=
